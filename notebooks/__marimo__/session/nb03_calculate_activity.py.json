          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h1 id=\"calculate-phenotypic-activity\">Calculate phenotypic activity</h1>\n<span class=\"paragraph\">Compute mean average precision (mAP) replicability scores using\n<a href=\"https://github.com/cytomining/copairs\" rel=\"noopener noreferrer\" target=\"_blank\">copairs</a>. mAP measures how\nsimilar replicates of a perturbation are relative to negative controls \u2014\nhigher values indicate stronger, more reproducible phenotypes.</span></span>"
          }
        }
